# ── Database ────────────────────────────────────────────────────────────────
# Local dev (SQLite) or production (Supabase/Postgres connection string)
DATABASE_URL=sqlite:///./constructask.db
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres   # Supabase pooler

# ── Auth (JWT) ──────────────────────────────────────────────────────────────
# REQUIRED in production. Set a long random string. (Dev falls back to an insecure key.)
JWT_SECRET_KEY=
JWT_EXPIRE_MINUTES=480
ENVIRONMENT=development   # set to "production" on the live host to enforce JWT_SECRET_KEY

# ── CORS (comma-separated frontend origins) ─────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-vercel-url.vercel.app

# ── AI assistant fallback (optional) ────────────────────────────────────────
# Free: get a Gemini key at https://aistudio.google.com/apikey  (starts AIza... or AQ.)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Or OpenAI (paid). Gemini is tried first if both are set.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Google sign-in (server-side Supabase session verification) ──────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ── Verifiable DPP issuer key (optional; auto-generated in dev) ──────────────
# In production set a persistent Ed25519 private key (hex) so signatures survive restarts.
DPP_ISSUER_PRIVATE_HEX=
DPP_ISSUER_ID=anton-steel-works
DPP_ISSUER_NAME=Anton Steel Works
