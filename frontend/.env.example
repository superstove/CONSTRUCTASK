# Backend API base URL (FastAPI). Local dev:
VITE_API_BASE_URL=http://127.0.0.1:8000

# Supabase (for "Sign in with Google"). Safe to expose — these are public keys.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Demo account used for the "Continue with Demo Account" auto-login (optional override).
VITE_DEMO_EMAIL=demo@constructask.dev
VITE_DEMO_PASSWORD=demo1234
